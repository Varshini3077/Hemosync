{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "@hemosync/types": ["../packages/types/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../packages/types/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage", "**/*.test.ts"]
}