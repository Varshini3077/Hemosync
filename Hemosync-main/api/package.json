{
  "name": "@hemosync/api",
  "version": "0.1.0",
  "private": true,
  "description": "HemoSync Azure Functions API — core orchestration engine",
  "main": "dist/api/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "func start",
    "dev": "func start --verbose",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@azure-rest/maps-route": "^1.0.0-beta.5",
    "@azure-rest/maps-search": "^2.0.0-beta.3",
    "@azure/ai-text-analytics": "^5.1.0",
    "@azure/communication-email": "^1.0.0",
    "@azure/communication-sms": "^1.1.0",
    "@azure/cosmos": "^4.0.0",
    "@azure/functions": "^4.0.0",
    "@azure/identity": "^4.0.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@azure/openai": "^2.0.0",
    "@azure/service-bus": "^7.9.0",
    "applicationinsights": "^3.0.0",
    "axios": "^1.6.0",
    "ioredis": "^5.3.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.35.0",
    "openai": "^6.32.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^@hemosync/types$": "<rootDir>/../packages/types/src/index.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "Node"
        }
      }
    }
  }
}
