# =============================================================================
# HemoSync — Environment Variables Reference
# Copy this file to .env and fill in your values. NEVER commit .env to git.
# All secrets in production are stored in Azure Key Vault.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure Subscription & Resource Group
# -----------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_GROUP=hemosync-rg
AZURE_LOCATION=centralindia

# -----------------------------------------------------------------------------
# Azure OpenAI (GPT-4o — parse-request function)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# -----------------------------------------------------------------------------
# Azure Cosmos DB (operational store — blood banks, broadcast jobs)
# -----------------------------------------------------------------------------
COSMOS_CONNECTION_STRING=AccountEndpoint=https://<account>.documents.azure.com:443/;AccountKey=<key>;
COSMOS_DATABASE_NAME=hemosync
COSMOS_BLOOD_BANKS_CONTAINER=blood-banks
COSMOS_REQUESTS_CONTAINER=requests
COSMOS_BROADCAST_JOBS_CONTAINER=broadcast-jobs

# -----------------------------------------------------------------------------
# Azure Cache for Redis (bank rank cache — sub-ms reads)
# -----------------------------------------------------------------------------
REDIS_CONNECTION_STRING=<your-redis>.redis.cache.windows.net:6380,password=<key>,ssl=True,abortConnect=False
REDIS_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Azure Database for PostgreSQL (audit + analytics store)
# -----------------------------------------------------------------------------
POSTGRES_HOST=<your-server>.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DATABASE=hemosync_audit
POSTGRES_USER=hemosync_admin
POSTGRES_PASSWORD=
POSTGRES_SSL_MODE=require

# Local dev override (matches docker-compose.yml)
# POSTGRES_HOST=localhost
# POSTGRES_USER=hemosync
# POSTGRES_PASSWORD=hemosync_dev
# POSTGRES_DATABASE=hemosync_audit

# -----------------------------------------------------------------------------
# Azure Service Bus (broadcast queue)
# -----------------------------------------------------------------------------
SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<policy>;SharedAccessKey=<key>
SERVICE_BUS_QUEUE_NAME=broadcast-queue

# -----------------------------------------------------------------------------
# Azure Communication Services (SMS + WhatsApp)
# -----------------------------------------------------------------------------
ACS_CONNECTION_STRING=endpoint=https://<resource>.communication.azure.com;accesskey=<key>
ACS_SMS_FROM_NUMBER=+1XXXXXXXXXX
ACS_WHATSAPP_CHANNEL_ID=

# -----------------------------------------------------------------------------
# MSG91 SMS Gateway (primary India SMS — fallback: ACS)
# -----------------------------------------------------------------------------
MSG91_AUTH_KEY=
MSG91_SENDER_ID=HMSYNC
MSG91_TEMPLATE_ID_REQUEST=
MSG91_TEMPLATE_ID_CONFIRM=
MSG91_ROUTE=4

# -----------------------------------------------------------------------------
# Azure Maps (distance + ETA calculation)
# -----------------------------------------------------------------------------
AZURE_MAPS_CLIENT_ID=
AZURE_MAPS_SUBSCRIPTION_KEY=

# -----------------------------------------------------------------------------
# Azure AI Speech (STT — browser-side voice input)
# -----------------------------------------------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# -----------------------------------------------------------------------------
# Azure API for FHIR (fallback donor queries)
# -----------------------------------------------------------------------------
FHIR_ENDPOINT=https://<workspace>-<fhir>.fhir.azurehealthcareapis.com
FHIR_AUDIENCE=https://<workspace>-<fhir>.fhir.azurehealthcareapis.com

# -----------------------------------------------------------------------------
# Azure Bot Service (Teams bot)
# -----------------------------------------------------------------------------
BOT_APP_ID=
BOT_APP_PASSWORD=
BOT_TENANT_ID=
MicrosoftAppType=MultiTenant

# -----------------------------------------------------------------------------
# Microsoft Graph API (user dept + org enrichment)
# -----------------------------------------------------------------------------
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# -----------------------------------------------------------------------------
# Power BI Embedded (analytics dashboard)
# -----------------------------------------------------------------------------
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=

# -----------------------------------------------------------------------------
# Azure API Management (gateway)
# -----------------------------------------------------------------------------
APIM_GATEWAY_URL=https://<apim-name>.azure-api.net
APIM_SUBSCRIPTION_KEY=

# -----------------------------------------------------------------------------
# Azure Key Vault (secret store — replaces all above in production)
# -----------------------------------------------------------------------------
KEY_VAULT_URI=https://<vault-name>.vault.azure.net/

# -----------------------------------------------------------------------------
# Azure Application Insights (telemetry)
# -----------------------------------------------------------------------------
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://centralindia-0.in.applicationinsights.azure.com/

# -----------------------------------------------------------------------------
# eRaktKosh Blood Bank Directory API
# -----------------------------------------------------------------------------
ERAKTKOSH_API_URL=https://eraktkosh.mohfw.gov.in/BLDAHIMS/bloodbank/
ERAKTKOSH_API_KEY=

# -----------------------------------------------------------------------------
# Azure Functions (local development)
# -----------------------------------------------------------------------------
FUNCTIONS_WORKER_RUNTIME=node
FUNCTIONS_EXTENSION_VERSION=~4
AzureWebJobsStorage=UseDevelopmentStorage=true
# For production: AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=<name>;AccountKey=<key>

# -----------------------------------------------------------------------------
# Web Dashboard (Vite — VITE_ prefix exposes to client bundle)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:7071/api
VITE_APIM_KEY=
VITE_SPEECH_REGION=centralindia
# VITE_SPEECH_KEY exposed client-side only for dev; use token endpoint in production

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
NODE_ENV=development
