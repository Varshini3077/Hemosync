{
  "name": "@hemosync/api",
  "version": "0.1.0",
  "private": true,
  "description": "HemoSync Azure Functions API — core orchestration engine",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "func start",
    "dev": "func start --verbose",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@azure/functions": "^4.0.0",
    "@azure/openai": "^1.0.0",
    "@azure/cosmos": "^4.0.0",
    "@azure/maps-search": "^1.0.0",
    "@azure/maps-route": "^1.0.0",
    "@azure/communication-sms": "^1.1.0",
    "@azure/communication-email": "^1.0.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@azure/service-bus": "^7.9.0",
    "@azure/identity": "^4.0.0",
    "@azure/ai-text-analytics": "^5.1.0",
    "applicationinsights": "^3.0.0",
    "axios": "^1.6.0",
    "ioredis": "^5.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@hemosync/types": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ioredis": "^4.28.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^@hemosync/types$": "<rootDir>/../packages/types/src/index.ts"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "Node"
        }
      }
    }
  }
}
