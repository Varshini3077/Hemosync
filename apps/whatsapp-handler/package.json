{
  "name": "@hemosync/whatsapp-handler",
  "version": "0.0.0",
  "private": true,
  "description": "HemoSync WhatsApp Handler — ACS webhook receiver for coordinator messages",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@azure/communication-messages": "^1.1.0",
    "@azure/identity": "^4.0.0",
    "@hemosync/types": "workspace:*",
    "axios": "^1.6.7",
    "express": "^4.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
